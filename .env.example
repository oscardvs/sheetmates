# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# ── Firebase (web app config; NEXT_PUBLIC_* is exposed to the browser) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── App ──
# Base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Firebase Admin SDK (server only) ──
# Base64-encoded service-account JSON. Used by /api/checkout and the Stripe
# webhook to read parts/pricing and write orders, bypassing client rules.
# On Firebase Hosting / Cloud Run, leave blank — Application Default
# Credentials are used automatically.
#   Generate with: base64 -w0 serviceAccount.json
FIREBASE_SERVICE_ACCOUNT=
