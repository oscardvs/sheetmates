{
  "name": "sheetmates-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for SheetMates: admin provisioning and TTL cleanup",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "set-admin": "npm run build && node lib/scripts/set-admin.js"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "private": true
}
